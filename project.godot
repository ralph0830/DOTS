; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DOTS"
config/description="DOTS - Godot 4 기반 2D 게임"
run/main_scene="res://scenes/slot/SlotMachine.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameConfig="*res://autoload/GameConfig.gd"
EventBus="*res://autoload/EventBus.gd"
WalletManager="*res://autoload/WalletManager.gd"
JackpotSystem="*res://autoload/JackpotSystem.gd"
AudioManager="*res://autoload/AudioManager.gd"
GameManager="*res://autoload/GameManager.gd"
ParticleBudget="*res://scripts/effects/ParticleBudget.gd"
SlowMotion="*res://scripts/effects/SlowMotion.gd"
BonusManager="*res://scripts/systems/BonusManager.gd"
SoulGauge="*res://scripts/systems/SoulGauge.gd"
LordState="*res://scripts/systems/LordState.gd"
UnitRegistry="*res://scripts/systems/UnitRegistry.gd"
ArtifactManager="*res://scripts/systems/ArtifactManager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
window/size/test_width=540
window/size/test_height=960

[layer_names]

2d_render/layer_1="Default"
2d_physics/layer_1="Default"
2d_physics/layer_2="Player"
2d_physics/layer_3="Enemy"
2d_physics/layer_4="Projectile"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
