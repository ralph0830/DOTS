# ============================================================
# Godot 4+ 전용 .gitignore
# ============================================================

# 에디터 캐시/임포트 결과 (빌드 시 자동 재생성되므로 커밋하지 않음)
.godot/

# Android 빌드 산출물
/android/build/

# CSV에서 자동 생성된 번역 파일
*.translation

# Godot 암호화 키 파일 (저장 데이터 암호화 사용 시)
# keyfile/

# 임시/백업
*.tmp
*.bak

# ============================================================
# 운영체제 / 에디터
# ============================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store

# Linux
*~

# IDE / 편집기
.vscode/
.idea/
*.swp
*.swo

# 테스트 캡처 스크린샷
captures/

# 빌드 산출물 (APK 등)
/build/

# Playwright MCP 임시
/.playwright-mcp/
